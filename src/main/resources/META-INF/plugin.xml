<?xml version="1.0" encoding="UTF-8"?>
<idea-plugin>
    <id>com.novelplugin.powershell-novel-reader</id>
    <name>PowerShell Novel Reader</name>
    <version>1.1.0</version>
    <vendor email="1285758660@qq.com" url="https://github.com/WBigPea/powershell-novel-reader">WBigPea</vendor>

    <description>
        <![CDATA[
        A novel reader disguised as a Windows PowerShell terminal inside your JetBrains IDE.
        伪装成 PowerShell 小说阅读器
        It looks exactly like a real terminal with dark theme, blue title bar, PS prompt and Consolas font, so nobody can tell you are reading novels.
        一款伪装成 PowerShell 终端的小说阅读器，支持六种伪装模式（日志/Diff/进度条/tail -f 等），阅读进度自动保存，可自定义翻页快捷键和每页行数。打开 Settings - Tools - PowerShell Novel Reader 选择 txt 文件后，在底部 PowerShell 窗口输入 cat book 即可阅读。
        ]]>
    </description>

    <change-notes>
        <![CDATA[
        <h3>v1.1.0</h3>
        <ul>
            <li>Add English / 增加英文支持</li>
       </ul>
        ]]>
    </change-notes>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService
                serviceImplementation="com.novelplugin.settings.NovelPluginSettings"/>

        <toolWindow
                id="PowerShell"
                anchor="bottom"
                icon="AllIcons.Actions.Execute"
                factoryClass="com.novelplugin.PowerShellNovelWindowFactory"
                canClose="true">
        </toolWindow>

        <applicationConfigurable
                parentId="tools"
                instance="com.novelplugin.settings.NovelSettingsConfigurable"
                id="com.novelplugin.NovelSettingsConfigurable"
                displayName="PowerShell Novel Reader"/>
    </extensions>

    <actions>
        <action
                id="com.novelplugin.ToggleNovelAction"
                class="com.novelplugin.actions.ToggleNovelAction"
                text="Toggle PowerShell Novel"
                description="Toggle PowerShell Novel Reader window">
            <keyboard-shortcut
                    first-keystroke="control alt N"
                    keymap="$default"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>